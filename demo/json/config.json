{
  "app_name": "My Awesome Application",
  "debug": false,
  "timezone": "Asia/Tokyo",
  "database": {
    "driver": "mysql",
    "host": "localhost",
    "port": 3306,
    "database": "myapp_db",
    "username": "myapp_user",
    "password": "secret_password",
    "charset": "utf8mb4",
    "collation": "utf8mb4_unicode_ci"
  },
  "cache": {
    "driver": "redis",
    "host": "localhost",
    "port": 6379,
    "ttl": 7200
  },
  "logging": {
    "level": "info",
    "driver": "file",
    "path": "/var/log/myapp.log",
    "max_files": 30
  },
  "mail": {
    "driver": "smtp",
    "host": "smtp.example.com",
    "port": 587,
    "username": "noreply@example.com",
    "password": "mail_secret",
    "encryption": "tls",
    "from_address": "noreply@example.com",
    "from_name": "My Awesome Application"
  },
  "features": {
    "user_registration": true,
    "email_verification": true,
    "two_factor_auth": false,
    "api_rate_limiting": true
  },
  "api": {
    "version": "v1",
    "rate_limit": 1000,
    "timeout": 30
  }
}